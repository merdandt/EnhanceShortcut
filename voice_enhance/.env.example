# Voice Enhance Service Environment Variables
# Copy this file to voice_enhance/.env and adjust as needed.
# These are merged on top of the root .env at deploy time (service wins).

# Max input size accepted by /enhance, in MB (upload or R2 object).
# Note: direct multipart uploads through Cloud Run are additionally capped
# at ~32 MB by the platform (HTTP/1 request limit) — use the r2_key mode
# for bigger files.
MAX_UPLOAD_MB=100

# Enhancement defaults (overridable per request via query params)
DEFAULT_NFE=64
DEFAULT_SOLVER=midpoint
DEFAULT_LAMBD=0.9
DEFAULT_TAU=0.5

# Where the enhancer_stage2 checkpoint lives. Leave unset:
#   - Docker image bakes it at /models/enhancer_stage2 (set in Dockerfile)
#   - local dev downloads to <repo>/models/enhancer_stage2 on first start
# MODEL_RUN_DIR=
