# =============================================================================
# EnhanceShortcut Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# GCP Configuration
PROJECT_ID=your-gcp-project-id
REGION=europe-west4
REPOSITORY_NAME=voice-tools

# Cloudflare R2 (S3-compatible) storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=https://your-public-bucket-domain
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=

# Client auth for voice_enhance (X-API-Key header).
# Generate with: openssl rand -hex 32
API_KEY=

# Telegram bot (@enhance_shortcut_bot) — token from BotFather
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Don't know yours? Message the bot — it replies with your ID.
TELEGRAM_USER_IDS=
# Webhook auth; generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# =============================================================================
# Service URLs (for local development)
# These are auto-populated during Cloud Run deployment
# =============================================================================

# VOICE_ENHANCE_SERVICE_URL=http://localhost:8081
